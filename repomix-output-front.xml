    const loadData = async () => {
      try {
        const [cats, ings] = await Promise.all([
          getCategoriesApi(),
          getIngredientsApi(),
        ]);

        setCategories(cats);
        setIngredients(ings);
      } catch {
        toast.error("Failed to load data");
      }
