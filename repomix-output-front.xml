<file path="components/recipes/NotFoundRecipe/NotFoundRecipe.module.css">
.wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px 16px;
  gap: 0;
  flex: 1;
}

.imageWrapper {
  position: relative;
  width: 361px;
  height: 267px;
  max-width: 100%;
  border-radius: 8px;
  overflow: hidden;
  margin-top: auto;
  margin-bottom: 32px;
}

.image {
  object-fit: cover;
}

.code {
  font-family: var(--font-family);
  font-weight: 600;
  font-size: 48px;
  line-height: 110%;
  display: flex;
  align-items: center;
  text-align: center;
  color: #000000;
  margin: 0 0 16px 0;
}

.text {
  font-family: var(--font-family);
  font-weight: 400;
  font-size: 24px;
  line-height: 29px;
  display: flex;
  align-items: center;
  text-align: center;
  color: #000000;
  margin: 0 0 32px 0;
}

.btn {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  padding: 16px;
  width: 361px;
  height: 56px;
  gap: 16px;
  background: #9b6c43;
  border-radius: 8px;
  color: var(--white);
  font-size: 16px;
  font-weight: 500;
  text-decoration: none;
  transition: opacity var(--transition-base);
  margin-bottom: auto;
}

.btn:hover {
  background: #6d554b;
  opacity: 1;
}

.btn:focus-visible {
  background: #9b6c43;
  box-shadow:
    0px 0px 0px 2px #ffffff,
    0px 0px 0px 6px rgba(78, 70, 180, 0.12);
  outline: none;
  opacity: 1;
}

.btn:active {
  background: #9b6c43;
  box-shadow:
    0px 0px 0px 2px #ffffff,
    0px 0px 0px 6px rgba(78, 70, 180, 0.12);
  outline: none;
  opacity: 1;
}

/* Tablet 768px */
@media (min-width: 768px) {
  .imageWrapper {
    width: 600px;
    height: 438px;
  }

  .code {
    font-size: 48px;
  }

  .btn {
    width: 340px;
  }
}

/* Desktop 1440px */
@media (min-width: 1440px) {
  .imageWrapper {
    width: 600px;
    height: 438px;
  }

  .btn {
    width: 288px;
  }
}
