@import 'modern-normalize/modern-normalize.css';
@import '../styles/variables.css';
@import '../styles/breakpoints.css';

html {
  height: 100%;
  scroll-behavior: smooth;
}

html,
body {
  max-width: 100vw;
  overflow-x: hidden;
}

body {
  min-height: 100%;
  display: flex;
  flex-direction: column;
  color: var(--darck-brown);
  background-color: var(--background);
  font-family: var(--font-family);
  font-weight: var(--font-weight-regular);
  font-size: 14px;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

*,
*::before,
*::after {
  box-sizing: border-box;
}

img,
picture,
video,
canvas,
svg {
  display: block;
  max-width: 100%;
}

input,
button,
textarea,
select {
  font: inherit;
}

a {
  color: inherit;
  text-decoration: none;
}

ul,
ol {
  list-style: none;
  padding: 0;
  margin: 0;
}

h1,
h2,
h3,
h4,
h5,
h6,
p {
  margin: 0;
}

/* Interactive elements */
a,
button,
[role='button'],
input[type='submit'],
input[type='button'],
input[type='reset'],
label[for],
select,
summary {
  cursor: pointer;
  transition:
    opacity var(--transition-base),
    color var(--transition-base),
    background-color var(--transition-base),
    border-color var(--transition-base);
}

@media (hover: hover) and (pointer: fine) {
  a:hover,
  button:hover,
  [role='button']:hover,
  input[type='submit']:hover,
  input[type='button']:hover,
  input[type='reset']:hover,
  label[for]:hover,
  select:hover,
  summary:hover {
    opacity: 0.85;
  }
}

button:disabled,
input:disabled,
select:disabled,
[disabled] {
  cursor: not-allowed;
  opacity: 0.6;
}

/* Layout utilities */
.container {
  width: 100%;
  max-width: var(--container-max-width);
  margin-inline: auto;
  padding-inline: var(--container-padding-mobile);
}

.page {
  display: flex;
  flex: 1;
  flex-direction: column;
  width: 100%;
}

.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

/* Typography scale — mobile-first (320px+) */
h1 {
  font-family: var(--font-family);
  font-weight: var(--font-weight-semibold);
  font-size: clamp(28px, 8vw, 32px);
  line-height: 1.2;
}

h2 {
  font-family: var(--font-family);
  font-weight: var(--font-weight-semibold);
  font-size: clamp(22px, 6vw, 28px);
  line-height: 1.25;
}

h3 {
  font-family: var(--second-family);
  font-weight: var(--font-weight-bold);
  font-size: clamp(18px, 4.5vw, 22px);
  line-height: 1.3;
}

@media (min-width: 393px) {
  body {
    font-size: 15px;
  }
}

@media (min-width: 768px) {
  body {
    font-size: 16px;
  }

  h1 {
    font-size: 48px;
  }

  h2 {
    font-size: 40px;
  }

  h3 {
    font-size: 24px;
  }
}

@media (min-width: 1440px) {
  h1 {
    font-size: 48px;
  }

  h2 {
    font-size: 40px;
  }
}
